---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            /* 1. Base Dark Theme */
            body {
                color: #000000;
                margin: 0;
                font-family: system-ui, -apple-system, sans-serif;
                background-color: #f7f3ed; /* Base off-white background */
            }

            main {
                width: 100%;
                overflow: hidden;
                position: relative; /* Keeps the absolute background contained */
            }

            /* Screen Reader Only */
            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border-width: 0;
            }

            /* --- ANIMATED GRADIENT MESH --- */
            .blob-container {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                overflow: hidden;
                z-index: -2;
                pointer-events: none; /* Prevents blobs from blocking clicks */
            }

            .blob {
                position: absolute;
                border-radius: 50%;
                filter: blur(120px);
                opacity: 0.5; /* Subtlety control */
                animation: float 20s infinite ease-in-out alternate;
            }

            .blob-blue {
                width: 60vw;
                height: 60vw;
                max-width: 500px;
                max-height: 500px;
                background: #453FFE; /* Your brand blue */
                top: -5%;
                left: 10%;
                animation-delay: -5s; /* Desync the movement */
            }

            .blob-pink {
                width: 50vw;
                height: 50vw;
                max-width: 400px;
                max-height: 900px;
                background: #ff90de; /* Soft pink complement */
                top: 20%;
                right: -15%;
                animation-delay: -5s; /* Desync the movement */
            }

            @keyframes float {
                0% { transform: translate(0, 0) scale(1); }
                50% { transform: translate(100px, 50px) scale(1.1); }
                100% { transform: translate(-50px, 100px) scale(0.9); }
            }
            /* ------------------------------ */

            /* 2. Hero Section */
            .hero {
                position: relative;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                min-height: 80vh;
                text-align: center;
                padding: 0 1rem;
            }
            
            .hero-logo {
                width: clamp(280px, 50vw, 1200px); 
                height: auto;
                margin-bottom: 0rem;
                filter: drop-shadow(0 0 50px rgba(69, 63, 254, 0.3)); /* Tinted drop shadow to match brand */
                z-index: 1;
            }

            .subtitle {
                font-size: clamp(1.2rem, 2vw, 1.25rem);
                color: #453FFE;
                max-width: 600px;
                margin: 1rem auto 10rem auto;
                line-height: 1.6;
                z-index: 1;
                text-align: left;
            }

            /* 3. Call to Action Buttons */
            .cta-group {
                display: flex;
                gap: 1rem;
                justify-content: center;
                flex-wrap: wrap;
                z-index: 1;
            }

            .btn {
                padding: 0.75rem 1.5rem;
                border-radius: 9px;
                font-weight: 600;
                text-decoration: none;
                transition: all 0.2s ease;
                font-size: 0.95rem;
                letter-spacing: 0.05em;
                text-transform: uppercase;
            }

            .btn.primary {
                background-color: #453FFE;
                color: white;
                box-shadow: 0 0 15px rgba(69, 63, 254, 0.4);
            }

            .btn.primary:hover {
                background-color: #2563eb;
                box-shadow: 0 0 25px rgba(69, 63, 254, 0.6);
                transform: translateY(-2px);
            }

            .btn.secondary {
                background-color: rgba(255, 255, 255, 0.4); /* Slightly visible background */
                color: #453FFE;
                border: 1px solid rgba(69, 63, 254, 0.2); /* Tinted border */
                backdrop-filter: blur(10px);
            }

            .btn.secondary:hover {
                background-color: rgba(255, 255, 255, 0.8);
                border-color: rgba(69, 63, 254, 0.4);
                transform: translateY(-2px);
            }

            /* 4. Features/Vectors Section */
            .vectors {
                max-width: 1200px;
                margin: 0 auto;
                padding: 4rem 1rem 8rem 1rem;
                position: relative; /* Keeps z-index stacking correct */
                z-index: 1;
            }

            .vectors-title {
                text-align: center;
                font-size: 2rem;
                margin-bottom: 3rem;
                color: #453FFE;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 2rem;
            }

            /* Updated Glassmorphism cards for light theme */
            .card {
                background: rgba(255, 255, 255, 0.6);
                border: 1px solid rgba(255, 255, 255, 0.8);
                border-radius: 16px;
                padding: 2rem;
                backdrop-filter: blur(12px);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); /* Soft shadow */
                transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
            }

            .card:hover {
                transform: translateY(-5px);
                border-color: rgba(69, 63, 254, 0.4);
                box-shadow: 0 10px 15px -3px rgba(69, 63, 254, 0.1);
            }

            .card h3 {
                margin-top: 0;
                color: #453FFE;
                font-size: 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .card p {
                color: #334155; /* Darker gray for readability on light background */
                font-size: 0.95rem;
                line-height: 1.6;
                margin-bottom: 0;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="blob-container">
                <div class="blob blob-blue"></div>
                <div class="blob blob-pink"></div>
            </div>

            <section class="hero">
                <h1 class="sr-only">Calculemus</h1>
                
                <img src="/calculemus_logo.png" alt="Calculemus Logo" class="hero-logo" />

                <p class="subtitle"> 
                    Leiden University's official AI team<br />
                </p>
                <div class="cta-group">
                    <a href="/team" class="btn primary">Meet the Team</a>
                    <a href="/news" class="btn secondary">Latest Work</a>
                </div>
            </section>

            <section class="vectors">
                <h2 class="vectors-title">What we do</h2>
                <p class="subtitle" style="text-align: center; margin: 0 auto 3rem auto;"> 
                    The AI team offers motivated students a good time to explore the applications of AI beyond their studies. We actively participate within AI challenges and organize events on our own.
                </p>
                <div class="grid">
                    <div class="card">
                        <h3>AI Competitions</h3>
                        <p>Find new ideas.</p>
                    </div>
                    <div class="card">
                        <h3>Community Events</h3>
                        <p>Inspire others.</p>
                    </div>
                    <div class="card">
                        <h3><...></h3>
                        <p>Your brilliant idea here.</p>
                    </div>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>