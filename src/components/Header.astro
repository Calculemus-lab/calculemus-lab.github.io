---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
    <nav>
        <!-- Top bar: Always visible (Title + Hamburger) -->
        <div class="nav-top">
            <h2><a href="/">{SITE_TITLE}</a></h2>
            <button id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="hamburger">
                    <line x1="3" y1="12" x2="21" y2="12" class="line-middle"></line>
                    <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
                    <line x1="3" y1="18" x2="21" y2="18" class="line-bottom"></line>
                </svg>
            </button>
        </div>

        <!-- The Menu: Centers links on desktop, acts as full-screen overlay on mobile -->
        <div id="nav-menu" class="nav-links">
            <div class="internal-links">
                <HeaderLink href="/">Home</HeaderLink>
                <HeaderLink href="/news">News</HeaderLink>
                <HeaderLink href="/events">Events</HeaderLink>
                <HeaderLink href="/team">Team</HeaderLink>
            </div>
            <div class="social-links">
                <!-- Instagram -->
                <a href="https://instagram.com/your-profile" target="_blank">
                    <span class="sr-only">Follow us on Instagram</span>
                    <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
                        <path fill="currentColor" d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.487.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"></path>
                    </svg>
                </a>
                <!-- LinkedIn -->
                <a href="https://linkedin.com/in/your-profile" target="_blank">
                    <span class="sr-only">Connect on LinkedIn</span>
                    <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
                        <path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"></path>
                    </svg>
                </a>
                <!-- Leiden University -->
                <a href="https://www.universiteitleiden.nl/" target="_blank" class="uni-link">
                    <span class="sr-only">Go to Leiden University</span>
                    <div class="uni-logo"></div>
                </a>
            </div>
        </div>
    </nav>
</header>

<style>
    /* =========================================
       DESKTOP STYLES (Default / > 768px)
       ========================================= */
    header {
        margin: 0;
        padding: 0;
        background: white; 
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
        position: relative;
    }
    nav {
        display: flex;
        align-items: center;
        padding: 0 1em;
        height: 70px; /* Fixed height makes vertical alignment perfect */
        max-width: 1200px;
        margin: 0 auto;
    }
    
    /* Top Bar (Title) */
    .nav-top {
        display: flex;
        align-items: center;
    }
    h2 {
        margin: 0;
        font-size: 1.2em;
        white-space: nowrap;
    }
    h2 a {
        text-decoration: none;
        color: var(--black); 
    }
    
    /* Hamburger strictly hidden on desktop */
    #menu-toggle {
        display: none; 
    }

    /* Flex magic: This takes up all space between title and right edge */
    .nav-links {
        display: flex;
        align-items: center;
        flex: 1; 
    }
    
    /* Center the internal links */
    .internal-links {
        display: flex;
        justify-content: center;
        gap: 1.5em;
        flex: 1; /* Pushes the social links to the far right */
    }
    .internal-links a {
        color: var(--black); 
        text-decoration: none;
        font-weight: 500;
        padding: 0.5em 0;
        border-bottom: 3px solid transparent;
        transition: border-color 0.2s;
    }
    .internal-links a:hover,
    .internal-links a.active {
        font-weight: bold;
        border-bottom-color: var(--accent);
    }
    
    /* Keep social links grouped on the right */
    .social-links {
        display: flex;
        align-items: center;
        gap: 1em;
    }
    .social-links a {
        display: flex;
        color: var(--black); 
        transition: opacity 0.2s;
    }
    .social-links a:hover {
        opacity: 0.7;
    }
    
    .uni-logo {
        width: 24px;
        height: 24px;
        background-color: currentColor; 
        -webkit-mask: url('/Leiden_University_seal.svg_-2686666985.png') no-repeat center / contain;
        mask: url('/Leiden_University_seal.svg_-2686666985.png') no-repeat center / contain;
    }

    /* =========================================
       MOBILE STYLES (< 768px)
       ========================================= */
    @media (max-width: 768px) {
        nav {
            flex-direction: column;
            align-items: flex-start;
            height: auto;
            padding: 0;
        }
        
        /* Top bar gets full width to push hamburger to right */
        .nav-top {
            width: 100%;
            height: 70px;
            padding: 0 1.5em;
            justify-content: space-between;
        }
        
        /* Show the hamburger */
        #menu-toggle {
            display: flex;
            align-items: center;
            background: transparent;
            border: none;
            cursor: pointer;
            color: var(--black);
            padding: 0.5em;
        }

        /* The collapsible menu becomes a full-screen dropdown */
        .nav-links {
            display: none; /* Hidden by default */
            flex-direction: column;
            width: 100%;
            height: calc(100vh - 70px); /* Fill screen below header */
            background: white;
            padding: 2em 1.5em;
            box-shadow: 0 4px 6px rgba(15, 23, 42, 0.05);
            /* Position absolute prevents it from pushing content down strangely */
            position: absolute;
            top: 70px;
            left: 0;
            z-index: 50;
        }
        .nav-links.open {
            display: flex; /* Shown via JS */
        }

        /* Large, centered links for easy tapping */
        .internal-links {
            flex-direction: column;
            flex: none; /* Remove desktop flex grow */
            width: 100%;
            text-align: center;
            gap: 1.5em;
            font-size: 1.5em;
        }

        /* Pushes socials to the absolute bottom of the screen */
        .social-links {
            margin-top: auto; 
            justify-content: center;
            width: 100%;
            padding-bottom: 2em;
            gap: 1.5em;
        }

        /* Hamburger Animation */
        #menu-toggle[aria-expanded="true"] .line-top { transform: translateY(6px) rotate(45deg); transform-origin: center; }
        #menu-toggle[aria-expanded="true"] .line-bottom { transform: translateY(-6px) rotate(-45deg); transform-origin: center; }
        #menu-toggle[aria-expanded="true"] .line-middle { opacity: 0; }
        .hamburger line { transition: transform 0.3s ease, opacity 0.3s ease; }
    }
</style>

<script>
    // Create a reusable function to set up the menu
    function setupMenu() {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('nav-menu');

        // Make sure the elements exist before adding listeners
        if (toggle && menu) {
            // Remove old listeners to prevent duplicates if navigating back and forth
            const newToggle = toggle.cloneNode(true);
            toggle.parentNode.replaceChild(newToggle, toggle);

            newToggle.addEventListener('click', () => {
                const isExpanded = newToggle.getAttribute('aria-expanded') === 'true';
                
                newToggle.setAttribute('aria-expanded', String(!isExpanded));
                menu.classList.toggle('open');
                
                // Locks body scroll so user can't scroll the site while menu is open
                document.body.style.overflow = isExpanded ? 'auto' : 'hidden';
            });
        }
    }

    // Run the script immediately on standard page load
    setupMenu();

    // ALSO run it if you ever decide to enable Astro View Transitions later!
    document.addEventListener('astro:page-load', setupMenu);
</script>